# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored — never commit real credentials.

# --- Required: Supabase (Postgres) connection ---
# From Supabase dashboard: Project -> Settings -> Database -> Connection string
# Use the "Session pooler" (port 5432), not the "Transaction pooler" (port 6543) —
# CTFd keeps long-lived pooled DB connections that the transaction pooler doesn't support well.
# Format:
#   postgresql+psycopg2://postgres.<project-ref>:<DB-PASSWORD>@<pooler-host>:5432/postgres?sslmode=require
# Example (replace every <...> placeholder):
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<DB-PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# --- Recommended: stable session secret ---
# If unset, CTFd auto-generates one and writes it to .ctfd_secret_key on disk.
# In Docker, that file lives inside the container and is lost on rebuild, which
# invalidates all sessions/cookies. Set a fixed value to avoid that.
# Generate one with: openssl rand -hex 32
SECRET_KEY=

